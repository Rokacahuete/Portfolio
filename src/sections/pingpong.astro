---
import Guy from "../components/Guy.astro";
import Section from "../components/Section.astro";
---

<Section>
    <div class="ping-pong">
        <Guy shape="capsule" size="300px" color="blue" target="ball" id="player-1" />
        <Guy shape="circle" color="yellow" scale=".2" id="ball" />
        <Guy shape="capsule" size="300px" color="red" target="ball" id="player-2" />
    </div>
</Section>

<style>
    .ping-pong {
        position: relative;
        width: 100%;
        height: 300px;
        background-color: rgba(0, 0, 0, 0.521);
        margin-block: 50px 75px;
        border: 2px solid var(--border-color);
    }

    @keyframes ball-x {
        from { left: 64px; }
        to   { left: calc(100% - 225px); }
    }
    @keyframes ball-y {
        from { top: -82px; }
        to   { top: 188px; }
    }
    :global(.ping-pong #ball) {
        left: calc(50% - 93px);
        top: 0;
        
        animation: ball-y 1.5s linear infinite alternate, ball-x 3.4677138s linear infinite alternate;
    }

    @keyframes player-y {
        from { top: -90px; }
        to   { top: -10px; }
    }
    :global(.ping-pong #player-1) {
        left: 0;

        animation: player-y 2s linear infinite alternate;
        animation-delay: .5s;
    }

    :global(.ping-pong #player-2) {
        left: calc(100% - 135px);

        animation: player-y 2s linear infinite alternate;
        animation-delay: 2.5s;
    }
</style>